# ──────────────────────────────────────────────────────────────
# SKIN@Mantraa - Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# ----- Site -------------------------------------------------------
# Public-facing base URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://skinmantraa.com

# ----- Appointments API -------------------------------------------
# Backend endpoint for booking form submissions
# APPOINTMENTS_API_URL=https://api.skinmantraa.com/appointments
# APPOINTMENTS_API_KEY=your_api_key_here

# ----- Email / Notifications --------------------------------------
# SMTP or transactional email service (e.g. Resend, SendGrid)
# EMAIL_FROM=no-reply@skinmantraa.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ----- Analytics --------------------------------------------------
# Google Analytics 4 Measurement ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ----- Maps -------------------------------------------------------
# Google Maps Embed API key (optional - for restricted embed usage)
# NEXT_PUBLIC_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXX
